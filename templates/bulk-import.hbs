<section class="animu-exxet-importer">
  <p class="animu-exxet-importer__lead">{{localize "ANIMU_EXXET.bulk.description"}}</p>

  {{#each packs}}
  <article class="animu-exxet-importer__card">
    <h3><i class="fas fa-{{#if (eq type 'Actor')}}users{{else}}suitcase{{/if}}"></i> {{label}}</h3>

    <div class="animu-exxet-importer__row" style="margin-bottom: 0.5rem;">
      <label>{{localize "ANIMU_EXXET.bulk.targetFolder"}}</label>
      <select name="worldFolder-{{collection}}" style="flex: 1;">
        <option value="">{{localize "ANIMU_EXXET.bulk.rootFolder"}}</option>
        {{#each ../worldFolders}}
        <option value="{{this.id}}">{{this.name}}</option>
        {{/each}}
      </select>
    </div>

    <div class="animu-exxet-importer__list" style="max-height: 300px; overflow-y: auto;">
      {{#each folders}}
      <div class="animu-exxet-importer__row" style="padding: 0.25rem 0;">
        <span style="flex: 1;">{{{indent}}}📁 {{name}}</span>
        <button type="button" data-action="import-folder" data-pack="{{../collection}}" data-folder="{{_id}}" data-recursive="false" title="{{localize 'ANIMU_EXXET.bulk.importFolder'}}">
          <i class="fas fa-download"></i>
        </button>
        <button type="button" data-action="import-folder" data-pack="{{../collection}}" data-folder="{{_id}}" data-recursive="true" title="{{localize 'ANIMU_EXXET.bulk.importFolderRecursive'}}">
          <i class="fas fa-layer-group"></i>
        </button>
      </div>
      {{/each}}
    </div>

    <div class="animu-exxet-importer__footer" style="margin-top: 0.5rem;">
      <button type="button" data-action="import-all" data-pack="{{collection}}">
        <i class="fas fa-download"></i> {{localize "ANIMU_EXXET.bulk.importAll"}}
      </button>
    </div>
  </article>
  {{/each}}
</section>
