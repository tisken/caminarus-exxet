<section class="animu-exxet-importer">
  <p class="animu-exxet-importer__lead">{{localize "ANIMU_EXXET.bulk.description"}}</p>

  <div class="animu-exxet-importer__options" style="margin-bottom: 0.75rem;">
    <i class="fas fa-folder-open"></i>
    <span><strong>{{localize "ANIMU_EXXET.bulk.targetFolder"}}:</strong> {{targetFolderName}}</span>
  </div>

  {{#each packs}}
  <article class="animu-exxet-importer__card">
    <div class="animu-exxet-importer__row">
      <h3 style="margin: 0;">{{label}}</h3>
      <button type="button" data-action="import-all" data-pack="{{collection}}">
        {{localize "ANIMU_EXXET.bulk.importAll"}}
      </button>
    </div>

    <div class="animu-exxet-importer__list" style="max-height: 350px; overflow-y: auto; margin-top: 0.5rem;">
      {{#each folders}}
      <div style="display: flex; align-items: center; gap: 0.25rem; padding: 0.15rem 0;">
        <span style="flex: 1; font-size: var(--font-size-12);">{{{indent}}}📁 {{name}}</span>
        <button type="button" data-action="import-folder" data-pack="{{../collection}}" data-folder="{{_id}}" data-recursive="false" title="{{localize 'ANIMU_EXXET.bulk.importFolder'}}" style="padding: 0.15rem 0.4rem; font-size: 0.75rem;">
          <i class="fas fa-download"></i>
        </button>
        <button type="button" data-action="import-folder" data-pack="{{../collection}}" data-folder="{{_id}}" data-recursive="true" title="{{localize 'ANIMU_EXXET.bulk.importFolderRecursive'}}" style="padding: 0.15rem 0.4rem; font-size: 0.75rem;">
          <i class="fas fa-layer-group"></i>
        </button>
      </div>
      {{/each}}
    </div>
  </article>
  {{/each}}
</section>
